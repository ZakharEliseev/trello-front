{
  "name": "rc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' tsc -b && NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "typecheck": "tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --color",
    "lint:fix": "eslint . --ext ts,tsx --fix --report-unused-disable-directives --max-warnings 0 --color",
    "lint:styles": "stylelint \"src/**/*.{scss,css}\" --allow-empty-input --max-warnings 0 --color",
    "lint:styles:fix": "stylelint \"src/**/*.{scss,css}\" --allow-empty-input --fix --max-warnings 0 --color",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-oauth/google": "^0.13.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/classnames": "^2.3.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "antd": "^6.2.0",
    "antd-style": "^4.1.0",
    "axios": "^1.13.6",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "motion": "^12.38.0",
    "pure-md5": "^0.2.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.71.1",
    "react-intersection-observer": "^10.0.2",
    "react-modal": "^3.16.3",
    "react-redux": "^9.2.0",
    "react-router": "^7.8.2",
    "vite-tsconfig-paths": "^5.1.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^4.1.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/qs": "^6.9.18",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@types/react-modal": "^3.16.3",
    "@types/validator": "^13.12.2",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitejs/plugin-react": "^5.0.1",
    "eslint": "^9.34.0",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^9.1.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.91.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-bundle-analyzer": "^0.0.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "resolutions": {
    "braces": "3.0.3",
    "postcss": "8.5.6",
    "micromatch": "4.0.8"
  }
}
